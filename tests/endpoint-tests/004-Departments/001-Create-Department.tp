--- TESTCASE Create Department - Success - 201 Created

--- HTTP
## TEST-EXPECT-STATUS: [201]
## TEST-HAS-BODY
POST {{ApiBaseUrl}}{{DepartmentsSection}}
Content-Type: application/json

{
  "name": "Backend",
  "code": "BE",
  "projectId": "{{ProjectId}}",
  "managerId": null
}

--- TEST
await tp.Test("Response should contain generated identifier and match request data.", async () =>
{
    dynamic body = await tp.Response.GetBodyAsExpandoAsync();
    NotNull(body);
    NotNull(body.id);
    Equal("Backend", (string)body.name);
    Equal("BE", (string)body.code);
    Equal(tp.GetVariable<string>("ProjectId", "projects"), (string)body.projectId);
    Null(body.managerId);

    tp.SetVariable("DepartmentId", (string)body.id, "departments");
});

--- END


