--- TESTCASE Create Project - Success - 201 Created

--- HTTP
## TEST-EXPECT-STATUS: [201]
## TEST-HAS-BODY
POST {{ApiBaseUrl}}{{ProjectsSection}}
Content-Type: application/json

{
  "name": "Application",
  "code": "APP",
  "divisionId": "{{DivisionId}}",
  "managerId": null
}

--- TEST
await tp.Test("Response should contain generated identifier and match request data.", async () =>
{
    dynamic body = await tp.Response.GetBodyAsExpandoAsync();
    NotNull(body);
    NotNull(body.id);
    Equal("Application", (string)body.name);
    Equal("APP", (string)body.code);
    Equal(tp.GetVariable<string>("DivisionId", "divisions"), (string)body.divisionId);
    Null(body.managerId);

    tp.SetVariable("ProjectId", (string)body.id, "projects");
});

--- END


