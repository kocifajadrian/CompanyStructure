--- TESTCASE Create Division - Success - 201 Created

--- HTTP
## TEST-EXPECT-STATUS: [201]
## TEST-HAS-BODY
POST {{ApiBaseUrl}}{{DivisionsSection}}
Content-Type: application/json

{
  "name": "Software Development",
  "code": "SWDEV",
  "companyId": "{{CompanyId}}",
  "managerId": null
}

--- TEST
await tp.Test("Response should contain generated identifier and match request data.", async () =>
{
    dynamic body = await tp.Response.GetBodyAsExpandoAsync();
    NotNull(body);
    NotNull(body.id);
    Equal("Software Development", (string)body.name);
    Equal("SWDEV", (string)body.code);
    Equal(tp.GetVariable<string>("CompanyId", "companies"), (string)body.companyId);
    Null(body.managerId);

    tp.SetVariable("DivisionId", (string)body.id, "divisions");
});

--- END


