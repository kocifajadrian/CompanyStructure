--- TESTCASE Create Employee - Success - 201 Created

--- HTTP
## TEST-EXPECT-STATUS: [201]
## TEST-HAS-BODY
POST {{ApiBaseUrl}}{{EmployeesSection}}
Content-Type: application/json

{
  "title": "Ing.",
  "firstName": "John",
  "lastName": "Doe",
  "phone": "+421 123 456 789",
  "email": "john.doe@example.com",
  "companyId": "{{CompanyId}}"
}

--- TEST
await tp.Test("Response should contain generated identifier and match request data.", async () =>
{
    dynamic body = await tp.Response.GetBodyAsExpandoAsync();
    NotNull(body);
    NotNull(body.id);
    Equal("Ing.", (string)body.title);
    Equal("John", (string)body.firstName);
    Equal("Doe", (string)body.lastName);
    Equal("+421 123 456 789", (string)body.phone);
    Equal("john.doe@example.com", (string)body.email);
    Equal(tp.GetVariable<string>("CompanyId", "companies"), (string)body.companyId);

    tp.SetVariable("EmployeeId", (string)body.id, "employees");
});

--- END


