--- TESTCASE Create Company - Success - 201 Created

--- HTTP
## TEST-EXPECT-STATUS: [201]
## TEST-HAS-BODY
POST {{ApiBaseUrl}}{{CompaniesSection}}
Content-Type: application/json

{
  "name": "Software Company",
  "code": "SWCOMP",
  "managerId": null
}

--- TEST
await tp.Test("Response should contain generated identifier and match request data.", async () =>
{
    dynamic body = await tp.Response.GetBodyAsExpandoAsync();
    NotNull(body);
    NotNull(body.id);
    Equal("Software Company", (string)body.name);
    Equal("SWCOMP", (string)body.code);
    Null(body.managerId);

    tp.SetVariable("CompanyId", (string)body.id, "companies");
});

--- END


